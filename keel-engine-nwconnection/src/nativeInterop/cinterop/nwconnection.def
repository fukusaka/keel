language = Objective-C
headers = Network/Network.h netinet/in.h dispatch/dispatch.h string.h Security/Security.h
linkerOpts = -framework Security

---

#include <Network/Network.h>
#include <netinet/in.h>
#include <dispatch/dispatch.h>
#include <string.h>
#include <Security/Security.h>

/*
 * NW_PARAMETERS_DISABLE_PROTOCOL and NW_PARAMETERS_DEFAULT_CONFIGURATION are
 * C macros that cast extern block constants. They cannot be bound directly by
 * cinterop; this wrapper creates plain TCP parameters without TLS.
 */
nw_parameters_t keel_nw_create_tcp_params(void) {
    return nw_parameters_create_secure_tcp(
        NW_PARAMETERS_DISABLE_PROTOCOL,
        NW_PARAMETERS_DEFAULT_CONFIGURATION
    );
}

/*
 * Creates TLS-enabled TCP parameters with the given identity.
 *
 * The TLS configure block sets the local identity via
 * sec_protocol_options_set_local_identity. The TCP configure block
 * uses NW_PARAMETERS_DEFAULT_CONFIGURATION (which is a C macro and
 * cannot be passed from Kotlin/Native).
 *
 * @param identity  sec_identity_t created from SecIdentityCreate + sec_identity_create.
 * @return TLS-enabled nw_parameters_t, or NULL on failure.
 */
nw_parameters_t keel_nw_create_tls_tcp_params(sec_identity_t identity) {
    if (!identity) return NULL;
    return nw_parameters_create_secure_tcp(
        ^(nw_protocol_options_t tls_options) {
            sec_protocol_options_t proto = nw_tls_copy_sec_protocol_options(tls_options);
            sec_protocol_options_set_local_identity(proto, identity);
        },
        NW_PARAMETERS_DEFAULT_CONFIGURATION
    );
}

/*
 * Creates a SecKeyRef from DER-encoded private key data.
 *
 * Wraps SecKeyCreateWithData with the necessary CFDictionary attributes
 * (kSecAttrKeyType, kSecAttrKeyClass) which require CFDictionaryCreateMutable
 * — awkward to use from Kotlin/Native due to CFDictionaryKeyCallBacks struct
 * pointer requirements.
 *
 * @param key_der   DER-encoded private key (PKCS#1 for RSA, SEC 1 for EC).
 * @param key_len   Length of key_der in bytes.
 * @param key_type  0 = RSA (kSecAttrKeyTypeRSA), 1 = EC (kSecAttrKeyTypeECSECPrimeRandom).
 * @return SecKeyRef on success, NULL on failure.
 */
SecKeyRef keel_nw_create_private_key(const void *key_der, uint32_t key_len, int key_type) {
    CFDataRef data = CFDataCreate(NULL, key_der, key_len);
    if (!data) return NULL;

    CFMutableDictionaryRef attrs = CFDictionaryCreateMutable(NULL, 2,
        &kCFTypeDictionaryKeyCallBacks, &kCFTypeDictionaryValueCallBacks);
    CFDictionarySetValue(attrs, kSecAttrKeyType,
        key_type == 1 ? kSecAttrKeyTypeECSECPrimeRandom : kSecAttrKeyTypeRSA);
    CFDictionarySetValue(attrs, kSecAttrKeyClass, kSecAttrKeyClassPrivate);

    SecKeyRef key = SecKeyCreateWithData(data, attrs, NULL);
    CFRelease(attrs);
    CFRelease(data);
    return key;
}

/* 127.0.0.1 in network byte order */
uint32_t keel_nw_loopback_addr(void) { return htonl(INADDR_LOOPBACK); }

/*
 * Callback types for async C wrappers.
 * Used by Kotlin/Native staticCFunction + StableRef to bridge
 * NWConnection's dispatch callbacks to coroutine continuations.
 */
typedef void (*keel_nw_read_callback)(uint32_t len, int is_complete, int error, void *ctx);
typedef void (*keel_nw_write_callback)(int error, void *ctx);
typedef void (*keel_nw_start_callback)(int result, void *ctx);

/*
 * Async read via NWConnection.
 *
 * Schedules nw_connection_receive and invokes the callback when data
 * arrives. No blocking — the caller suspends via coroutine and is
 * resumed by the callback.
 *
 * Data is copied from dispatch_data_t into the caller's buffer
 * segment-by-segment via dispatch_data_apply (same as blocking version).
 *
 * Limitation: NWConnection does not provide a receive API that writes into
 * a pre-allocated buffer. The kernel delivers data as dispatch_data_t,
 * so a memcpy into NativeBuf is unavoidable. Measured cost: ~0.1-0.4 us
 * for small packets, ~1-2 us for 64 KB. Zero-copy wrapping is deferred
 * to Phase 6+ (requires NativeBuf MemoryOwner abstraction).
 *
 * @param conn     NWConnection to read from.
 * @param buf      Destination buffer.
 * @param buf_len  Maximum bytes to read.
 * @param callback Invoked on completion with (bytes_copied, is_complete, error, ctx).
 * @param ctx      Opaque pointer passed to callback (StableRef to continuation).
 */
void keel_nw_read_async(nw_connection_t conn,
                         void *buf, uint32_t buf_len,
                         keel_nw_read_callback callback, void *ctx) {
    nw_connection_receive(conn, 1, buf_len,
        ^(dispatch_data_t content, nw_content_context_t context,
          bool is_complete, nw_error_t error)
        {
            __block uint32_t copied = 0;
            int failed = error ? 1 : 0;
            if (!failed && content) {
                dispatch_data_apply(content,
                    ^(dispatch_data_t region, size_t offset,
                      const void *ptr, size_t size)
                    {
                        if (copied + size > buf_len) {
                            size = buf_len - copied;
                        }
                        memcpy((uint8_t *)buf + copied, ptr, size);
                        copied += (uint32_t)size;
                        return (bool)(copied < buf_len);
                    });
            }
            callback(copied, is_complete ? 1 : 0, failed, ctx);
        });
}

/*
 * Async write via NWConnection.
 *
 * Creates a dispatch_data_t from the caller's buffer, sends it via
 * nw_connection_send, and invokes the callback on completion.
 * No blocking.
 *
 * dispatch_data_create copies buf by default (DISPATCH_DATA_DESTRUCTOR_DEFAULT).
 * The caller's NativeBuf stays valid because flush() holds a retain.
 *
 * @param conn     NWConnection to write to.
 * @param buf      Source buffer.
 * @param buf_len  Number of bytes to send.
 * @param callback Invoked on completion with (error, ctx).
 * @param ctx      Opaque pointer passed to callback (StableRef to continuation).
 */
void keel_nw_write_async(nw_connection_t conn,
                          const void *buf, uint32_t buf_len,
                          keel_nw_write_callback callback, void *ctx) {
    dispatch_data_t data = dispatch_data_create(buf, buf_len,
        dispatch_get_global_queue(0, 0), DISPATCH_DATA_DESTRUCTOR_DEFAULT);

    nw_connection_send(conn, data, NW_CONNECTION_DEFAULT_MESSAGE_CONTEXT, false,
        ^(nw_error_t error) {
            callback(error ? 1 : 0, ctx);
        });
}

/*
 * Batched async write via NWConnection (scatter/gather equivalent).
 *
 * Concatenates multiple buffers into a single dispatch_data_t using
 * dispatch_data_create_concat, then sends the combined data in one
 * nw_connection_send call. This is the NWConnection equivalent of
 * POSIX writev().
 *
 * Each buffer is copied into dispatch_data_t
 * (DISPATCH_DATA_DESTRUCTOR_DEFAULT). The concatenation itself is
 * zero-copy (dispatch_data_t chains internally without memcpy).
 *
 * @param conn       NWConnection to write to.
 * @param bufs       Array of source buffer pointers.
 * @param lens       Array of buffer lengths (bytes).
 * @param count      Number of buffers.
 * @param callback   Invoked on completion with (error, ctx).
 * @param ctx        Opaque pointer passed to callback.
 */
void keel_nw_writev_async(nw_connection_t conn,
                           const void **bufs, const uint32_t *lens, int count,
                           keel_nw_write_callback callback, void *ctx) {
    dispatch_data_t combined = dispatch_data_empty;
    dispatch_queue_t q = dispatch_get_global_queue(0, 0);
    for (int i = 0; i < count; i++) {
        dispatch_data_t chunk = dispatch_data_create(bufs[i], lens[i],
            q, DISPATCH_DATA_DESTRUCTOR_DEFAULT);
        dispatch_data_t prev = combined;
        combined = dispatch_data_create_concat(prev, chunk);
    }
    nw_connection_send(conn, combined, NW_CONNECTION_DEFAULT_MESSAGE_CONTEXT, false,
        ^(nw_error_t error) {
            callback(error ? 1 : 0, ctx);
        });
}

/*
 * Send TCP FIN (half-close) via NWConnection.
 *
 * Sends NULL content with NW_CONNECTION_FINAL_MESSAGE_CONTEXT and
 * is_complete=true, which triggers a TCP FIN to the peer.
 * The read side remains open.
 *
 * Fire-and-forget: no callback needed because the caller does not
 * depend on shutdown completion (unlike flush).
 */
void keel_nw_shutdown_output(nw_connection_t conn) {
    nw_connection_send(conn, NULL, NW_CONNECTION_FINAL_MESSAGE_CONTEXT, true,
        ^(nw_error_t error) {
            /* no-op: fire and forget */
        });
}

/*
 * Start a connection asynchronously and invoke callback when ready.
 *
 * Sets a state handler on the connection, calls nw_connection_start,
 * and invokes the callback when the connection reaches ready or fails.
 * No blocking.
 *
 * @param conn     NWConnection to start.
 * @param queue    Dispatch queue for the connection's callbacks.
 * @param callback Invoked with 0 on ready, -1 on failure.
 * @param ctx      Opaque pointer passed to callback (StableRef to continuation).
 */
void keel_nw_start_conn_async(nw_connection_t conn, dispatch_queue_t queue,
                               keel_nw_start_callback callback, void *ctx) {
    /* Guard: state handler may fire multiple times (e.g. ready then cancelled).
     * The callback must be invoked exactly once to avoid double-resume of
     * the Kotlin coroutine continuation. */
    __block int called = 0;
    nw_connection_set_queue(conn, queue);
    nw_connection_set_state_changed_handler(conn,
        ^(nw_connection_state_t state, nw_error_t error) {
            if (called) return;
            if (state == nw_connection_state_ready) {
                called = 1;
                callback(0, ctx);
            } else if (state == nw_connection_state_failed ||
                       state == nw_connection_state_cancelled) {
                called = 1;
                callback(-1, ctx);
            }
        });
    nw_connection_start(conn);
}

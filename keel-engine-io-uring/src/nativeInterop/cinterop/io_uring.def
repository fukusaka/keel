headers = liburing.h sys/utsname.h
linkerOpts.linux = -luring-ffi -L/usr/lib/x86_64-linux-gnu
compilerOpts.linux = -I/usr/include -I/usr/include/x86_64-linux-gnu

---

#include <liburing.h>
#include <stdlib.h>

/*
 * Allocate and fill an iovec array on the heap for use with io_uring_prep_writev.
 * The iovec is heap-allocated so it remains valid until the CQE arrives.
 * Caller must free with keel_free_iovec() after the CQE is processed.
 */
static struct iovec *keel_alloc_iovec(const void **bases, const size_t *lens, int count) {
    struct iovec *iov = (struct iovec *)malloc(count * sizeof(struct iovec));
    if (!iov) return NULL;
    for (int i = 0; i < count; i++) {
        iov[i].iov_base = (void *)bases[i];
        iov[i].iov_len = lens[i];
    }
    return iov;
}

static void keel_free_iovec(struct iovec *iov) {
    free(iov);
}

/*
 * Provided buffer ring helpers for multi-shot receive.
 *
 * Multi-shot recv (IORING_RECV_MULTISHOT) combined with provided buffers
 * (IOSQE_BUFFER_SELECT) allows the kernel to select a buffer from a
 * pre-registered ring for each incoming packet. One SQE produces multiple
 * CQEs, eliminating per-read SQE resubmission overhead.
 *
 * Wrappers are needed because IORING_CQE_BUFFER_SHIFT and IOSQE_BUFFER_SELECT
 * are preprocessor constants that Kotlin/Native cinterop cannot bind directly.
 * Marked static — same rationale as keel_htons above.
 */

/* Extract buffer ID from CQE flags (flags >> IORING_CQE_BUFFER_SHIFT). */
static unsigned short keel_cqe_get_buf_id(unsigned int cqe_flags) {
    return cqe_flags >> IORING_CQE_BUFFER_SHIFT;
}

/* Check if CQE has the BUFFER flag set (provided buffer was used). */
static int keel_cqe_has_buffer(unsigned int cqe_flags) {
    return (cqe_flags & IORING_CQE_F_BUFFER) != 0;
}

/* Check if CQE has the MORE flag set (multi-shot SQE still armed). */
static int keel_cqe_has_more(unsigned int cqe_flags) {
    return (cqe_flags & IORING_CQE_F_MORE) != 0;
}

/* Set IOSQE_BUFFER_SELECT flag and buf_group on an SQE for provided buffers. */
static void keel_sqe_set_buffer_select(struct io_uring_sqe *sqe, unsigned short bgid) {
    sqe->flags |= IOSQE_BUFFER_SELECT;
    sqe->buf_group = bgid;
}

/*
 * Prepare a multi-shot recv SQE with provided buffer selection.
 *
 * io_uring_prep_recv_multishot is an inline function in liburing.h and cannot
 * be bound directly by Kotlin/Native cinterop. This wrapper combines:
 * 1. io_uring_prep_recv_multishot(sqe, sockfd, NULL, 0, 0) — multishot recv
 * 2. IOSQE_BUFFER_SELECT flag + buf_group — kernel selects from provided ring
 *
 * The kernel delivers one CQE per incoming data segment, each with
 * IORING_CQE_F_BUFFER set and the buffer ID in cqe->flags. The SQE remains
 * armed (IORING_CQE_F_MORE) until the connection closes or buffers are exhausted.
 */
static void keel_prep_recv_multishot(struct io_uring_sqe *sqe, int sockfd, unsigned short bgid) {
    io_uring_prep_recv(sqe, sockfd, NULL, 0, 0);
    sqe->ioprio |= IORING_RECV_MULTISHOT;
    sqe->flags |= IOSQE_BUFFER_SELECT;
    sqe->buf_group = bgid;
}

/*
 * Prepare a zero-copy send SQE (IORING_OP_SEND_ZC, Linux 6.0+).
 *
 * Unlike regular IORING_OP_SEND, the kernel sends data directly from the
 * user-space buffer without copying to the socket buffer. This produces
 * TWO CQEs per operation:
 *   1. Send result (res = bytes sent, flags may include IORING_CQE_F_MORE)
 *   2. Buffer release notification (kernel done with user buffer)
 *
 * The caller MUST NOT free/reuse the buffer until the second CQE arrives.
 * Use keel_cqe_has_more() on the first CQE to check if a second follows.
 */
static void keel_prep_send_zc(struct io_uring_sqe *sqe, int sockfd,
                              const void *buf, size_t len, int flags,
                              unsigned int zc_flags) {
    io_uring_prep_send_zc(sqe, sockfd, buf, len, flags, zc_flags);
}

/*
 * Prepare a zero-copy sendmsg SQE (IORING_OP_SENDMSG_ZC, Linux 6.1+).
 *
 * Combines gather write (iovec) with zero-copy send. The kernel sends
 * data directly from user-space buffers described by the msghdr's iovec
 * without copying to the socket buffer.
 *
 * Like SEND_ZC, this produces TWO CQEs:
 *   1. Send result (res = bytes sent, flags may include IORING_CQE_F_MORE)
 *   2. Buffer release notification (kernel done with user buffers)
 *
 * The caller MUST NOT free/reuse the buffers until the second CQE.
 * The msghdr and its iovec array must remain valid until the second CQE.
 */
#ifndef IORING_OP_SENDMSG_ZC
#define IORING_OP_SENDMSG_ZC 57
#endif

static struct msghdr *keel_alloc_msghdr(struct iovec *iov, int iovlen) {
    struct msghdr *msg = (struct msghdr *)calloc(1, sizeof(struct msghdr));
    if (!msg) return NULL;
    msg->msg_iov = iov;
    msg->msg_iovlen = iovlen;
    return msg;
}

static void keel_free_msghdr(struct msghdr *msg) {
    free(msg);
}

static void keel_prep_sendmsg_zc(struct io_uring_sqe *sqe, int sockfd,
                                 void *msg, unsigned int flags) {
    io_uring_prep_sendmsg_zc(sqe, sockfd, (struct msghdr *)msg, flags);
}

/* ====================================================================
 * Fixed files (IORING_REGISTER_FILES, Linux 5.1+)
 *
 * Registers file descriptors with the io_uring ring, allowing the kernel
 * to skip fd table lookup on every SQE submission (~100-200ns per SQE).
 * Registered fds are referenced by index rather than raw fd number.
 * ==================================================================== */

/*
 * Register an array of file descriptors with the ring.
 * Returns 0 on success, negative errno on failure.
 * The fds array can contain -1 for unused slots.
 */
static int keel_register_files(struct io_uring *ring, const int *fds, unsigned count) {
    return io_uring_register_files(ring, fds, count);
}

/*
 * Update registered files at [offset] with new fds.
 * Use fd=-1 to unregister a slot.
 * Returns number of fds updated on success, negative errno on failure.
 */
static int keel_register_files_update(struct io_uring *ring, unsigned offset,
                                      const int *fds, unsigned count) {
    return io_uring_register_files_update(ring, offset, fds, count);
}

/* Unregister all previously registered files. */
static int keel_unregister_files(struct io_uring *ring) {
    return io_uring_unregister_files(ring);
}

/*
 * Set IOSQE_FIXED_FILE flag on an SQE.
 * The SQE's fd field must contain the registered file index (not the raw fd).
 * Must be called after io_uring_prep_* which sets sqe->fd.
 */
static void keel_sqe_set_fixed_file(struct io_uring_sqe *sqe) {
    sqe->flags |= IOSQE_FIXED_FILE;
}

/* ====================================================================
 * Registered buffers (IORING_REGISTER_BUFFERS, Linux 5.1+)
 *
 * Pre-registers userspace buffers with the kernel, pinning pages once
 * at registration time. SEND_ZC_FIXED can then reference these buffers
 * by index, avoiding per-send page pinning overhead.
 * ==================================================================== */

/*
 * Register an array of buffers with the ring.
 * bases and lens are parallel arrays of buffer addresses and sizes.
 * Returns 0 on success, negative errno on failure.
 */
static int keel_register_buffers(struct io_uring *ring,
                                 const void **bases, const size_t *lens,
                                 int count) {
    struct iovec *iovs = (struct iovec *)malloc(count * sizeof(struct iovec));
    if (!iovs) return -12; /* ENOMEM */
    for (int i = 0; i < count; i++) {
        iovs[i].iov_base = (void *)bases[i];
        iovs[i].iov_len = lens[i];
    }
    int ret = io_uring_register_buffers(ring, iovs, count);
    free(iovs);
    return ret;
}

/* Unregister all previously registered buffers. */
static int keel_unregister_buffers(struct io_uring *ring) {
    return io_uring_unregister_buffers(ring);
}

/*
 * Prepare a zero-copy send SQE using a registered (fixed) buffer.
 * buf_index references the buffer in the registered array.
 * Avoids per-send page pinning — the buffer is already pinned.
 */
static void keel_prep_send_zc_fixed(struct io_uring_sqe *sqe, int sockfd,
                                    const void *buf, size_t len, int flags,
                                    unsigned int zc_flags, unsigned buf_index) {
    io_uring_prep_send_zc_fixed(sqe, sockfd, buf, len, flags, zc_flags, buf_index);
}

/* ====================================================================
 * Capability probing
 * ==================================================================== */

/* Opcode probe: checks if the running kernel supports a specific io_uring opcode. */
static struct io_uring_probe *keel_get_probe_ring(struct io_uring *ring) {
    return io_uring_get_probe_ring(ring);
}
static int keel_opcode_supported(const struct io_uring_probe *p, int op) {
    return io_uring_opcode_supported(p, op);
}
static void keel_probe_free(struct io_uring_probe *probe) {
    io_uring_free_probe(probe);
}

/* Kernel version extraction via uname(2). Manual parsing to avoid sscanf
 * (glibc 2.38 introduces __isoc23_sscanf which causes link errors). */
#include <sys/utsname.h>
static int keel_parse_version(const char *s, int idx) {
    int v[2] = {0, 0};
    int part = 0;
    for (const char *p = s; *p && part < 2; p++) {
        if (*p >= '0' && *p <= '9') {
            v[part] = v[part] * 10 + (*p - '0');
        } else if (*p == '.') {
            part++;
        } else {
            break;
        }
    }
    return v[idx];
}
static int keel_kernel_version_major(void) {
    struct utsname buf;
    uname(&buf);
    return keel_parse_version(buf.release, 0);
}
static int keel_kernel_version_minor(void) {
    struct utsname buf;
    uname(&buf);
    return keel_parse_version(buf.release, 1);
}

/* IORING_OP constants for probe (may not be in older liburing headers). */
#ifndef IORING_OP_SEND_ZC
#define IORING_OP_SEND_ZC 53
#endif
#ifndef IORING_OP_SENDMSG_ZC
#define IORING_OP_SENDMSG_ZC 57
#endif
#ifndef IORING_OP_MSG_RING
#define IORING_OP_MSG_RING 40
#endif

/* Ring setup flags (may not be in older liburing headers). */
#ifndef IORING_SETUP_COOP_TASKRUN
#define IORING_SETUP_COOP_TASKRUN (1U << 8)
#endif
#ifndef IORING_SETUP_SINGLE_ISSUER
#define IORING_SETUP_SINGLE_ISSUER (1U << 12)
#endif
#ifndef IORING_SETUP_DEFER_TASKRUN
#define IORING_SETUP_DEFER_TASKRUN (1U << 13)
#endif

static unsigned int keel_setup_coop_taskrun(void) { return IORING_SETUP_COOP_TASKRUN; }
static unsigned int keel_setup_single_issuer(void) { return IORING_SETUP_SINGLE_ISSUER; }
static unsigned int keel_setup_defer_taskrun(void) { return IORING_SETUP_DEFER_TASKRUN; }

/* ====================================================================
 * MSG_RING opcode (Linux 5.18+)
 *
 * Delivers a CQE on a target ring from the source ring's SQE. Used by
 * keel to wake up a peer EventLoop without an eventfd_write syscall
 * when the source thread is itself on an io_uring EventLoop pthread.
 *
 * `io_uring_prep_msg_ring(sqe, fd, len, data, flags)`
 *   - `fd`   = target ring's file descriptor (raw or registered)
 *   - `len`  = delivered as `res` in the target CQE
 *   - `data` = delivered as `user_data` in the target CQE
 *   - `flags` = MSG_RING flags (0 for basic mode)
 *
 * TWO CQEs are produced:
 *   1. Source ring — completion of the MSG_RING op (res = 0 or -errno)
 *   2. Target ring — synthesised from the SQE fields above
 *
 * The source CQE arrives on the source ring in the normal order of ops
 * and is consumed by the source EventLoop's CQE drain loop via a
 * user_data token.
 * ==================================================================== */

/* Read the ring's file descriptor. Used when preparing MSG_RING SQEs
 * so peer EventLoops can target each other's rings by raw fd. */
static int keel_ring_fd(struct io_uring *ring) {
    return ring->ring_fd;
}

/* Prepare an IORING_OP_MSG_RING SQE targeting `target_ring_fd`. On
 * completion the target ring will receive a CQE with res=`len` and
 * user_data=`data`. */
static void keel_prep_msg_ring(struct io_uring_sqe *sqe, int target_ring_fd,
                               unsigned int len, unsigned long long data,
                               unsigned int flags) {
    io_uring_prep_msg_ring(sqe, target_ring_fd, len, data, flags);
}

/* ====================================================================
 * Self-registered ring fd (IORING_REGISTER_RING_FDS, Linux 5.18+)
 *
 * Registers the ring's own file descriptor so subsequent
 * `io_uring_enter` syscalls (issued implicitly by
 * `io_uring_submit_and_wait` on every EventLoop iteration) use the
 * registered index and take the `IORING_ENTER_REGISTERED_RING` fast
 * path, skipping the kernel's per-syscall fd-table lookup.
 *
 * Pure enter-syscall optimisation with no observable behaviour change
 * and no kernel state outside the ring itself. Teardown is handled by
 * `io_uring_queue_exit`, but keel calls `io_uring_unregister_ring_fd`
 * explicitly in the EL `onExitHook` for symmetry and to fail fast if
 * the pairing ever breaks.
 * ==================================================================== */

/* Register the ring's own fd. Returns 1 on success (number of fds
 * registered), negative errno on failure. Must be called on the
 * submitter task (EL pthread under SINGLE_ISSUER). */
static int keel_register_ring_fd(struct io_uring *ring) {
    return io_uring_register_ring_fd(ring);
}

/* Unregister the ring's own fd. Returns 1 on success, negative errno
 * on failure. Must be called on the submitter task. */
static int keel_unregister_ring_fd(struct io_uring *ring) {
    return io_uring_unregister_ring_fd(ring);
}

/* ====================================================================
 * Direct-allocated multishot accept (Linux 5.19+)
 *
 * `io_uring_prep_multishot_accept_direct` combines two optimisations:
 *   - multishot: one SQE produces multiple accept CQEs (keeps the SQE
 *     armed until cancel or error).
 *   - direct + IORING_FILE_INDEX_ALLOC: the kernel picks a free slot
 *     in the registered file table and places the accepted fd there,
 *     reporting the allocated index in `cqe->res` instead of the raw fd.
 *     This saves the userspace `io_uring_register_files_update` syscall
 *     that keel currently issues per accept to register the client fd.
 *
 * Requires `IORING_REGISTER_FILES` to have been set up on the ring
 * (i.e. `fixedFiles` capability). The raw fd is never exposed to
 * userspace for direct-allocated slots — subsequent ops must use
 * `IOSQE_FIXED_FILE` and the index, and cleanup is via
 * `register_files_update(slot, -1)` which closes the kernel-held fd.
 *
 * Wrapper needed because `io_uring_prep_multishot_accept_direct` is
 * an inline function in liburing.h.
 * ==================================================================== */
static void keel_prep_multishot_accept_direct(struct io_uring_sqe *sqe, int fd,
                                              struct sockaddr *addr,
                                              socklen_t *addrlen, int flags) {
    io_uring_prep_multishot_accept_direct(sqe, fd, addr, addrlen, flags);
}

/* ====================================================================
 * IORING_OP_SHUTDOWN (Linux 5.11+)
 *
 * Offloads `shutdown(2)` to io_uring. Needed when the fd is only
 * known by its fixed-file index (direct-allocated accept): the POSIX
 * `shutdown(fd, how)` path requires a raw fd which direct-allocated
 * slots do not expose to userspace. With `IOSQE_FIXED_FILE` set, the
 * SQE's `fd` field is interpreted as the registered index.
 *
 * For traditional register-from-raw-fd slots, `shutdown(2)` is still
 * usable and cheaper (one syscall vs SQE + CQE roundtrip); the
 * io_uring path is opt-in for the direct-alloc case.
 *
 * Wrapper needed because `io_uring_prep_shutdown` is an inline
 * function in liburing.h.
 * ==================================================================== */
static void keel_prep_shutdown(struct io_uring_sqe *sqe, int fd, int how) {
    io_uring_prep_shutdown(sqe, fd, how);
}

/* ====================================================================
 * NAPI busy-poll registration (Linux 6.9+)
 *
 * Registers a NAPI busy-poll configuration on the ring. When the
 * kernel waits for CQEs (io_uring_enter with GETEVENTS), instead of
 * sleeping on an IRQ-driven wake-up it busy-polls the NIC drivers
 * associated with sockets registered on the ring. Removes the
 * packet-to-wakeup IRQ latency (~1-3 µs per packet on typical NICs)
 * at the cost of higher CPU utilisation while polling.
 *
 * The io_uring ring automatically tracks NAPI IDs of the sockets
 * used with it; no per-socket SO_BUSY_POLL setup is required.
 *
 * liburing 2.5 (the Ubuntu 24.04 system package) does NOT expose
 * `io_uring_register_napi` or the struct — the feature was added in
 * liburing 2.6. We define the structure and opcode numbers here and
 * invoke `io_uring_register` via `syscall(2)` directly. The kernel
 * ABI is stable: IORING_REGISTER_NAPI = 27, IORING_UNREGISTER_NAPI = 28
 * (per linux/io_uring.h from kernel 6.9+).
 * ==================================================================== */

#include <sys/syscall.h>
#include <unistd.h>
#include <errno.h>

#ifndef IORING_REGISTER_NAPI
#define IORING_REGISTER_NAPI    27
#endif
#ifndef IORING_UNREGISTER_NAPI
#define IORING_UNREGISTER_NAPI  28
#endif

/* Match struct io_uring_napi layout (kernel linux/io_uring.h 6.9+).
 * Named `keel_io_uring_napi` to avoid collision with future
 * liburing headers that may declare the same struct. */
struct keel_io_uring_napi {
    unsigned int  busy_poll_to;       /* busy-poll timeout in microseconds */
    unsigned char prefer_busy_poll;   /* 0 or 1 — prefer busy poll over IRQ */
    unsigned char pad[3];
    unsigned long long resv;
};

/* Register NAPI busy-poll config. Returns 0 on success, negative
 * errno on failure (-EINVAL if kernel <6.9 or struct layout mismatch,
 * -EOPNOTSUPP if CONFIG_NET_RX_BUSY_POLL is disabled). */
static int keel_register_napi(struct io_uring *ring,
                              unsigned int busy_poll_to_us,
                              unsigned char prefer_busy_poll) {
    struct keel_io_uring_napi napi;
    napi.busy_poll_to = busy_poll_to_us;
    napi.prefer_busy_poll = prefer_busy_poll;
    napi.pad[0] = 0;
    napi.pad[1] = 0;
    napi.pad[2] = 0;
    napi.resv = 0;
    long ret = syscall(__NR_io_uring_register, ring->ring_fd,
                       IORING_REGISTER_NAPI, &napi, 1);
    if (ret < 0) return -errno;
    return (int)ret;
}

/* Unregister NAPI busy-poll config. Returns 0 on success, negative
 * errno on failure. */
static int keel_unregister_napi(struct io_uring *ring) {
    long ret = syscall(__NR_io_uring_register, ring->ring_fd,
                       IORING_UNREGISTER_NAPI, NULL, 0);
    if (ret < 0) return -errno;
    return (int)ret;
}

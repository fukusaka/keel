headers = openssl/ssl.h openssl/err.h openssl/bio.h openssl/x509.h openssl/pem.h
compilerOpts.osx = -I/opt/homebrew/opt/openssl@3/include
compilerOpts.linux = -I/usr/include -I/usr/include/x86_64-linux-gnu
linkerOpts.osx = -L/opt/homebrew/opt/openssl@3/lib -lssl -lcrypto
# Kotlin/Native lld uses --no-allow-shlib-undefined by default, rejecting
# indirect glibc references (stat, dlclose etc.) in shared libs.
linkerOpts.linux = -L/usr/lib/x86_64-linux-gnu -lssl -lcrypto --allow-shlib-undefined

---

#include <openssl/ssl.h>
#include <openssl/err.h>
#include <openssl/bio.h>
#include <openssl/x509.h>
#include <openssl/pem.h>
#include <string.h>

// ============================================================
// Error string helper
// ============================================================

// Get human-readable error string from OpenSSL error queue.
static const char* keel_openssl_err_string(void) {
    return ERR_reason_error_string(ERR_get_error());
}

// ============================================================
// Pointer-based BIO adapter for TlsCodec protect/unprotect
// ============================================================
// Mirrors Mbed TLS's keel_mbedtls_bio_ctx: recv/send callbacks
// read from and write to caller-owned IoBuf memory directly —
// no intermediate buffer copies beyond AEAD encrypt/decrypt.

// BIO context: holds pointers into caller-owned IoBuf memory.
// Pointers are valid ONLY during a single protect/unprotect call.
typedef struct {
    // recv side: input IoBuf (ciphertext for unprotect)
    const unsigned char* recv_ptr;
    size_t recv_remaining;

    // send side: output IoBuf (ciphertext for protect, handshake for unprotect)
    unsigned char* send_ptr;
    size_t send_capacity;
    size_t send_written;
} keel_openssl_bio_ctx;

// BIO read callback: reads from recv_ptr (caller's IoBuf).
// Returns -1 with BIO_set_retry_read when recv buffer is exhausted.
static int keel_openssl_bio_read(BIO *bio, char *buf, int len) {
    keel_openssl_bio_ctx *ctx = (keel_openssl_bio_ctx *)BIO_get_data(bio);
    if (ctx->recv_remaining == 0) {
        BIO_set_retry_read(bio);
        return -1;
    }
    size_t n = (size_t)len < ctx->recv_remaining ? (size_t)len : ctx->recv_remaining;
    memcpy(buf, ctx->recv_ptr, n);
    ctx->recv_ptr += n;
    ctx->recv_remaining -= n;
    return (int)n;
}

// BIO write callback: writes to send_ptr (caller's IoBuf).
// Returns -1 with BIO_set_retry_write when send buffer is full.
static int keel_openssl_bio_write(BIO *bio, const char *buf, int len) {
    keel_openssl_bio_ctx *ctx = (keel_openssl_bio_ctx *)BIO_get_data(bio);
    size_t avail = ctx->send_capacity - ctx->send_written;
    if (avail == 0) {
        BIO_set_retry_write(bio);
        return -1;
    }
    size_t n = (size_t)len < avail ? (size_t)len : avail;
    memcpy(ctx->send_ptr + ctx->send_written, buf, n);
    ctx->send_written += n;
    return (int)n;
}

// BIO ctrl callback: must handle BIO_CTRL_FLUSH at minimum.
static long keel_openssl_bio_ctrl(BIO *bio, int cmd, long num, void *ptr) {
    (void)bio; (void)num; (void)ptr;
    if (cmd == BIO_CTRL_FLUSH) return 1;
    return 0;
}

// Singleton BIO_METHOD — created once, never freed (process-lifetime).
static BIO_METHOD *keel_openssl_bio_method_instance = NULL;

static BIO_METHOD* keel_openssl_bio_method(void) {
    if (keel_openssl_bio_method_instance) return keel_openssl_bio_method_instance;
    // BIO_TYPE_NONE = 0 means custom, user-defined BIO.
    BIO_METHOD *m = BIO_meth_new(BIO_TYPE_NONE, "keel_openssl_bio");
    BIO_meth_set_read(m, keel_openssl_bio_read);
    BIO_meth_set_write(m, keel_openssl_bio_write);
    BIO_meth_set_ctrl(m, keel_openssl_bio_ctrl);
    keel_openssl_bio_method_instance = m;
    return m;
}

// Create pointer-based BIO and attach to SSL.
// SSL takes ownership of the BIO — do NOT call BIO_free.
// The bio_ctx must outlive the SSL object (caller manages lifetime).
// Returns 0 on success, -1 on failure.
static int keel_openssl_bio_setup(SSL *ssl, keel_openssl_bio_ctx *ctx) {
    BIO_METHOD *method = keel_openssl_bio_method();
    if (!method) return -1;
    BIO *bio = BIO_new(method);
    if (!bio) return -1;
    BIO_set_data(bio, ctx);
    BIO_set_init(bio, 1);
    // Use same BIO for both read and write — callbacks distinguish
    // via recv_ptr/send_ptr in the context.
    // BIO_up_ref so SSL_set_bio doesn't double-free the single BIO.
    BIO_up_ref(bio);
    SSL_set_bio(ssl, bio, bio);
    return 0;
}

// ============================================================
// SNI wrapper (SSL_set_tlsext_host_name is a macro)
// ============================================================

static int keel_openssl_set_sni(SSL *ssl, const char *hostname) {
    return SSL_set_tlsext_host_name(ssl, hostname);
}

// ============================================================
// ALPN helpers
// ============================================================

// Get the negotiated ALPN protocol. Returns the protocol string pointer
// (NOT null-terminated) and sets *len_out to the length.
// Returns NULL if no ALPN was negotiated.
static const unsigned char* keel_openssl_get_alpn(const SSL *ssl, unsigned int *len_out) {
    const unsigned char *data = NULL;
    unsigned int len = 0;
    SSL_get0_alpn_selected(ssl, &data, &len);
    *len_out = len;
    return data;
}

// ============================================================
// Certificate and key loading from PEM strings
// ============================================================

// Load a PEM certificate chain into SSL_CTX.
// Returns 1 on success, 0 on failure.
static int keel_openssl_ctx_load_pem_cert(SSL_CTX *ctx, const char *pem, int pem_len) {
    BIO *bio = BIO_new_mem_buf(pem, pem_len);
    if (!bio) return 0;

    X509 *cert = PEM_read_bio_X509(bio, NULL, NULL, NULL);
    if (!cert) {
        BIO_free(bio);
        return 0;
    }

    int ret = SSL_CTX_use_certificate(ctx, cert);
    X509_free(cert);

    // Load additional chain certificates if present.
    if (ret == 1) {
        X509 *chain_cert;
        while ((chain_cert = PEM_read_bio_X509(bio, NULL, NULL, NULL)) != NULL) {
            SSL_CTX_add_extra_chain_cert(ctx, chain_cert);
            // SSL_CTX_add_extra_chain_cert takes ownership — do NOT free chain_cert.
        }
        // Clear the error from the last failed PEM_read_bio_X509 (EOF).
        ERR_clear_error();
    }

    BIO_free(bio);
    return ret;
}

// Load a PEM private key into SSL_CTX.
// Returns 1 on success, 0 on failure.
static int keel_openssl_ctx_load_pem_key(SSL_CTX *ctx, const char *pem, int pem_len) {
    BIO *bio = BIO_new_mem_buf(pem, pem_len);
    if (!bio) return 0;

    EVP_PKEY *pkey = PEM_read_bio_PrivateKey(bio, NULL, NULL, NULL);
    BIO_free(bio);
    if (!pkey) return 0;

    int ret = SSL_CTX_use_PrivateKey(ctx, pkey);
    EVP_PKEY_free(pkey);
    return ret;
}

// Load PEM CA certificates into SSL_CTX's trust store.
// Returns the number of certs loaded (>= 1 on success), 0 on failure.
static int keel_openssl_ctx_load_ca_pem(SSL_CTX *ctx, const char *pem, int pem_len) {
    BIO *bio = BIO_new_mem_buf(pem, pem_len);
    if (!bio) return 0;

    X509_STORE *store = SSL_CTX_get_cert_store(ctx);
    int count = 0;
    X509 *cert;
    while ((cert = PEM_read_bio_X509(bio, NULL, NULL, NULL)) != NULL) {
        if (X509_STORE_add_cert(store, cert) == 1) {
            count++;
        }
        X509_free(cert);
    }
    ERR_clear_error();
    BIO_free(bio);
    return count;
}

// ============================================================
// Peer certificate (DER encoding)
// ============================================================

// Get the peer certificate in DER format.
// Returns the DER bytes via *out and the length via *len_out.
// Caller must free *out with OPENSSL_free().
// Returns 0 on success, -1 if no peer certificate.
static int keel_openssl_get_peer_cert_der(const SSL *ssl,
                                           unsigned char **out,
                                           int *len_out) {
    X509 *cert = SSL_get0_peer_certificate(ssl);
    if (!cert) return -1;
    int len = i2d_X509(cert, out);
    // SSL_get0_peer_certificate does NOT increment ref count — do NOT free.
    if (len < 0) return -1;
    *len_out = len;
    return 0;
}

// ============================================================
// POSIX socket helpers (for OpenSslEchoTest — kept from original)
// ============================================================

#include <sys/socket.h>
#include <netinet/in.h>
#include <unistd.h>

static int keel_openssl_create_server(int port) {
    int fd = socket(AF_INET, SOCK_STREAM, 0);
    if (fd < 0) return -1;
    int opt = 1;
    setsockopt(fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));

    struct sockaddr_in addr;
    memset(&addr, 0, sizeof(addr));
    addr.sin_family = AF_INET;
    addr.sin_addr.s_addr = htonl(INADDR_ANY);
    addr.sin_port = htons(port);

    if (bind(fd, (struct sockaddr*)&addr, sizeof(addr)) < 0) {
        close(fd);
        return -2;
    }
    if (listen(fd, 1) < 0) {
        close(fd);
        return -3;
    }
    return fd;
}

static int keel_openssl_get_port(int fd) {
    struct sockaddr_in addr;
    socklen_t len = sizeof(addr);
    if (getsockname(fd, (struct sockaddr*)&addr, &len) < 0) return -1;
    return ntohs(addr.sin_port);
}

headers = arpa/inet.h sys/eventfd.h
---
#include <arpa/inet.h>
#include <sys/eventfd.h>
#include <unistd.h>

/*
 * inet_pton/inet_ntop wrappers for Linux.
 *
 * On Linux, cinterop binds these from <arpa/inet.h> but some
 * cross-compilation configurations fail to resolve them.
 * Explicit wrappers ensure reliable binding.
 *
 * On macOS, these are available directly via platform.darwin
 * and do not need C wrappers.
 */
static inline int keel_inet_pton(int af, const char *src, void *dst) {
    return inet_pton(af, src, dst);
}
static inline const char *keel_inet_ntop(int af, const void *src, char *dst, unsigned int size) {
    return inet_ntop(af, src, dst, (socklen_t)size);
}

/*
 * eventfd wrappers for EventLoop wakeup mechanism.
 * eventfd(2) provides a more efficient wakeup than pipe(2) on Linux:
 * single fd instead of two, and kernel-optimized for signaling.
 */
static int keel_eventfd_create(void) {
    return eventfd(0, EFD_NONBLOCK);
}

static int keel_eventfd_write(int fd) {
    uint64_t val = 1;
    return write(fd, &val, sizeof(val));
}

static int keel_eventfd_read(int fd) {
    uint64_t val;
    return read(fd, &val, sizeof(val));
}
